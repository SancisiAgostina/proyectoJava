<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
    fx:controller="interfaces.menu_reportes.ControladorMenuReportes"
    stylesheets="@../styles.css">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    <Label text="Menu de Reportes"/>
    <Button text="Reporte de Presentismo" onAction="#sobreBotonReportePresentismo"/>
    <Button text="Reporte de Asignatura" onAction="#sobreBotonReporteAsignaturas"/>
    <Button text="Reporte de Alumnos Libres" onAction="#sobreBotonReporteAlumnosLibres"/>
    <Button text="Volver" onAction="#sobreBotonVolver"/>
</VBox>