<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
    fx:controller="interfaces.menu_reportes.ControladorSubMenuAlumnosLibres"
    stylesheets="@../styles.css">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    <Label text="Menu de Reportes de Alumnos Libres"/>
    <StackPane alignment="CENTER" prefWidth="320.0" maxWidth="Infinity">
        <children>
            <ComboBox fx:id="comboBoxAnios" editable="true" promptText="Selecciona o escribe un año..." />
        </children>
    </StackPane>
    <Label fx:id="labelMensaje" style="-fx-font-size: 14px; -fx-font-weight: bold;" visible="false"/>

    <HBox spacing="10.0" alignment="CENTER" maxWidth="Infinity">
        <Button text="Generar Reporte de Alumnos Libres" onAction="#sobreBotonReporteAlumnosLibres"/>
        <Button text="Volver" onAction="#sobreBotonVolver"/>
    </HBox>
</VBox>