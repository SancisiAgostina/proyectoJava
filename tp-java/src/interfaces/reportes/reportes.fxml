<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.StackPane?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
    fx:controller="interfaces.reportes.ControladorReportes"
    stylesheets="@../styles.css">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label fx:id="labelTituloReporte" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <StackPane fx:id="contenedorTabla" VBox.vgrow="ALWAYS" />

    <HBox spacing="10.0" alignment="CENTER" maxWidth="Infinity">
        <Button text="Generar Reporte" onAction="#sobreBotonGenerarReporte"/>
        <Button text="Volver" onAction="#sobreBotonVolver"/>
    </HBox>
</VBox>